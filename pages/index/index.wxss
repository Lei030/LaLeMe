/* 容器 */
.container {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 自定义导航 - 活力黄 */
.custom-nav {
  position: fixed;
  top: 0;
  width: 100%;
  background: #FFD100;
  z-index: 1000;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}
.nav-content {
  height: 44px;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
}
.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  letter-spacing: 2rpx;
}

/* 地图 */
.map {
  width: 100%;
  height: 100vh;
}

/* 搜索框 */
.search-container {
  position: absolute;
  top: 200rpx;
  left: 30rpx;
  right: 30rpx;
  background: #ffffff;
  border-radius: 40rpx;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.12);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 4rpx solid transparent;
  overflow: hidden;
  z-index: 999;
}
.search-container.expanded {
  border-color: #FFD100;
}
.search-bar {
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  height: 90rpx;
}
.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  margin-left: 20rpx;
}
.clear-icon {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #ddd;
  color: #fff;
  border-radius: 50%;
  font-size: 24rpx;
  flex-shrink: 0;
}
.suggestions-list {
  max-height: 450rpx;
  border-top: 1rpx solid #f5f5f5;
  background: #fff;
}
.suggestion-item {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #fafafa;
}
.suggestion-item:active {
  background: #f5f8ff;
}
.s-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #222;
}
.s-addr {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}
.close-suggest {
  text-align: center;
  padding: 20rpx;
  font-size: 24rpx;
  color: #999;
}
.close-suggest:active {
  background: #f5f5f5;
}

/* 侧边功能栏 */
.tool-bar {
  position: absolute;
  right: 30rpx;
  bottom: 240rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.tool-btn {
  width: 96rpx;
  height: 96rpx;
  background: #ffffff;
  border-radius: 50%;
  text-align: center;
  line-height: 96rpx;
  font-size: 44rpx;
  padding: 0;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.1);
  overflow: hidden;
}
.tool-btn:active {
  transform: scale(0.9);
}
.tool-btn.active {
  background: #FFD100;
}

/* 标记指针 */
.center-pointer {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -100%);
  display: none;
  flex-direction: column;
  align-items: center;
  pointer-events: none;
  z-index: 500;
}
.center-pointer.active {
  display: flex;
  animation: bounce 0.5s infinite alternate;
}
@keyframes bounce {
  from { transform: translate(-50%, -100%); }
  to { transform: translate(-50%, -110%); }
}
.pointer-icon {
  font-size: 48rpx;
}
.pointer-label {
  background: #FFD100;
  color: #333;
  font-size: 22rpx;
  font-weight: bold;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  margin-top: 10rpx;
}

/* 底部通用面板 */
.bottom-panel {
  position: absolute;
  bottom: 40rpx;
  left: 30rpx;
  right: 30rpx;
  background: #ffffff;
  border-radius: 40rpx;
  padding: 40rpx;
  box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.08);
}
.panel-header {
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
}
.nav-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}
.nav-target {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.close-nav {
  font-size: 28rpx;
  color: #999;
  padding: 10rpx;
  margin-left: 20rpx;
  flex-shrink: 0;
}

.confirm-btn, .start-nav-btn {
  background: #FFD100;
  color: #333;
  text-align: center;
  padding: 28rpx;
  border-radius: 24rpx;
  font-weight: 900;
  font-size: 30rpx;
  box-shadow: 0 8rpx 0 #E6BC00;
}
.confirm-btn:active, .start-nav-btn:active {
  transform: translateY(4rpx);
  box-shadow: none;
}

/* 路线模式 */
.mode-selector {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
  background: #f8f8f8;
  padding: 10rpx;
  border-radius: 20rpx;
}
.mode-item {
  font-size: 24rpx;
  padding: 15rpx 30rpx;
  border-radius: 15rpx;
  transition: 0.2s;
  color: #666;
}
.mode-item.active {
  background: #FFD100;
  color: #333;
  font-weight: bold;
}

/* 实时导航 */
.nav-guide-bar {
  position: absolute;
  top: 200rpx;
  left: 30rpx;
  right: 30rpx;
  background: #FFD100;
  color: #333;
  padding: 30rpx 40rpx;
  border-radius: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 10rpx 30rpx rgba(255, 209, 0, 0.4);
}
.guide-info {
  flex: 1;
  min-width: 0;
}
.guide-inst {
  font-size: 32rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.guide-detail {
  font-size: 24rpx;
  color: #555;
  margin-top: 4rpx;
}
.exit-nav-btn {
  flex-shrink: 0;
  background: rgba(0,0,0,0.05);
  padding: 10rpx 24rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: bold;
  margin-left: 20rpx;
}

/* 评分模态框 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}
.rating-card {
  width: 80%;
  background: white;
  border-radius: 40rpx;
  padding: 50rpx;
  text-align: center;
}
.rating-title {
  display: block;
  font-weight: 800;
  font-size: 32rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.stars-row {
  display: flex;
  justify-content: center;
  gap: 10rpx;
  margin: 40rpx 0;
}

/* 半星评分 */
.star-item {
  position: relative;
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.star-half {
  position: absolute;
  top: 0;
  width: 50%;
  height: 100%;
  z-index: 2;
}
.star-left { left: 0; }
.star-right { right: 0; }
.star-bg {
  font-size: 60rpx;
  filter: grayscale(1);
  opacity: 0.3;
}
.star-fg {
  position: absolute;
  left: 0;
  top: 0;
  font-size: 60rpx;
  line-height: 70rpx;
  filter: grayscale(0);
  opacity: 0;
  transition: opacity 0.2s;
}
.star-fg.full {
  opacity: 1;
}
.star-fg.half {
  opacity: 1;
  width: 50%;
  overflow: hidden;
}

.rating-footer {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}
.rating-footer button {
  flex: 1;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 20rpx;
  border: none;
}
.btn-cancel {
  background: #f5f5f5;
  color: #999;
}
.btn-confirm {
  background: #FFD100;
  color: #333;
  font-weight: bold;
}
